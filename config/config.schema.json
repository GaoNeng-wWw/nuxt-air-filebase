{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "SiteConfigSchema",
  "type": "object",
  "properties": {
    "colors": {
      "type": "object",
      "properties": {
        "dark": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "default": {
                "type": "string"
              },
              "foreground": {
                "type": "string"
              }
            }
          }
        },
        "light": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "default": {
                "type": "string"
              },
              "foreground": {
                "type": "string"
              }
            }
          }
        }
      },
      "description": "主题色, 会随机选取"
    },
    "license": {
      "type": "object",
      "properties": {
        "startYear": {
          "type": "string",
          "description": "协议文件生效起始年份"
        },
        "name": {
          "type": "string",
          "description": "作者名"
        },
        "title": {
          "type": "string",
          "description": "展示在页脚的协议名称"
        },
        "url": {
          "type": "string",
          "description": "该协议的正文链接"
        }
      },
      "required": ["title", "url"]
    }
  },
  "required": ["authorName", "startYear", "introduction", "license"],
  "additionalProperties": false
}
